# Copy this file to .env and replace the placeholder values with your MongoDB Atlas connection details.
# Example:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/drought_predictor?retryWrites=true&w=majority
# DATABASE_NAME=drought_predictor

MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/drought_predictor?retryWrites=true&w=majority
DATABASE_NAME=drought_predictor
